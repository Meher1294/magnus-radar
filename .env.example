# ============ MAGNUS RADAR — ENV TEMPLATE ============
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el .env real al repo.

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET=cambia-esto-por-un-token-largo-aleatorio

# --- Frontend ---
PUBLIC_API_URL=https://api.magnusradar.cl
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Scrapers ---
SEIA_USER_AGENT=MagnusRadar/0.1 (contacto@magnusradar.cl)
SCRAPER_SCHEDULE_SEIA=0 6 * * *
SCRAPER_SCHEDULE_DGA=0 7 * * 1
SCRAPER_SCHEDULE_SMA=0 8 * * *

# --- Airtable (CRM) ---
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_LEADS=Leads

# --- Resend / Email para alertas ---
RESEND_API_KEY=re_XXXXXXXXXXXX
EMAIL_FROM=alertas@magnusradar.cl

# --- Deploy ---
DEPLOY_HOST=187.127.19.173
DEPLOY_USER=magnus
DEPLOY_PATH=/opt/magnus-radar
